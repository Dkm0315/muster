    "prepublishOnly": "rm -rf dist && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.79.1",
    "@musterhq/core": "workspace:*",
    "@musterhq/gateway": "workspace:*"
  },
  "description": "Muster CLI \u2014 the auditable agent harness you run from your terminal.",
  "license": "MIT",
  "author": "Muster contributors",
  "repository": {
    "type": "git",
