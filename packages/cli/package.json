  },
  "homepage": "https://themuster.dev",
  "bugs": "https://github.com/Dkm0315/muster/issues",
  "keywords": [
    "agent-harness",
    "ai-agent",
    "ai-agents",
    "governed-agents",
    "production-ai",
    "mcp",
