{
  "name": "@musterhq/cli",
  "version": "0.1.8",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "muster": "dist/index.js",
    "hc": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
