    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Dkm0315/muster#readme",
  "bugs": "https://github.com/Dkm0315/muster/issues",
  "keywords": [
    "ai",
    "agent",
    "llm",
    "harness",
    "agent-framework",
