{
  "schemaVersion": 1,
  "id": "github",
  "name": "Muster GitHub",
  "version": "0.1.0",
  "kind": "tool",
  "slot": "developer",
  "entrypoint": "src/index.ts",
  "description": "Read-only GitHub repository, issue, and pull request inspection tools. Authenticated requests use a declared token secret from the active capability context.",
  "permissions": [
    "network",
    "secrets"
  ],
  "sandbox": "network_limited",
  "secrets": [
    "GITHUB_PERSONAL_ACCESS_TOKEN",
    "GITHUB_TOKEN"
  ],
  "evals": [
    "evals/github-read.json"
  ],
  "implementedTools": [
    "github_repo_summary",
    "github_issue_search",
    "github_pull_request_list"
  ],
  "status": "v0: read-only GitHub API tools with token redaction by construction; write actions remain delegated to explicit MCP/CLI workflows.",
  "readiness": {
    "level": "verified",
    "status": "beta",
    "actionability": "local_tool",
    "owner": "muster-core",
    "surfaces": [
      "cli"
    ],
    "setup": {
      "urls": [
        "https://github.com/settings/tokens",
        "https://cli.github.com/manual/gh_auth_login"
      ],
      "requiredEnv": [
        "GITHUB_PERSONAL_ACCESS_TOKEN"
      ],
      "requiredAnyEnv": [],
      "credentialStorage": "env"
    },
    "diagnostics": {
      "doctorCommand": "muster plugins check github",
      "smokeCommand": "muster capability inspect capability-packs/github",
      "latencyBudgetMs": 1000,
      "requiresLiveCredentials": true
    },
    "safety": {
      "risk": "high",
      "permissionMode": "ask",
      "mutationApproval": "required",
      "resultCapBytes": 65536,
      "secretRedaction": true
    },
    "evidence": {
      "unitTests": [
        "packages/core/test/capability-load.test.ts",
        "packages/core/test/capability.test.ts"
      ],
      "qaSuites": [
        "pack_readiness"
      ],
      "liveArtifacts": [],
      "docs": [
        "README.md",
        "docs/RELEASE_TRAIN.md"
      ]
    }
  }
}
