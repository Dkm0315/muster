{
  "schemaVersion": 1,
  "id": "codex",
  "name": "Muster Codex Runtime",
  "version": "0.1.0",
  "kind": "tool",
  "slot": "agent-runtime",
  "entrypoint": "src/index.ts",
  "description": "Codex CLI runtime setup, readiness, session policy, and latency triage workflows.",
  "permissions": [],
  "sandbox": "read_only",
  "evals": [
    "evals/codex-runtime.json"
  ],
  "implementedTools": [
    "codex_runtime_setup_plan",
    "codex_runtime_readiness",
    "codex_session_policy",
    "codex_runtime_latency_triage"
  ],
  "status": "v0: Codex runtime orchestration policy; execution remains in Muster's runCodex adapter.",
  "readiness": {
    "level": "setup_plan",
    "status": "beta",
    "actionability": "setup_plan",
    "owner": "muster-core",
    "surfaces": [
      "cli"
    ],
    "setup": {
      "urls": [
        "https://github.com/openai/codex"
      ],
      "requiredEnv": [],
      "requiredAnyEnv": [],
      "credentialStorage": "none"
    },
    "diagnostics": {
      "doctorCommand": "muster plugins check codex",
      "smokeCommand": "muster capability inspect capability-packs/codex",
      "latencyBudgetMs": 1000,
      "requiresLiveCredentials": false
    },
    "safety": {
      "risk": "low",
      "permissionMode": "allow_when_scoped",
      "mutationApproval": "never",
      "resultCapBytes": 65536,
      "secretRedaction": true
    },
    "evidence": {
      "unitTests": [
        "packages/core/test/capability-load.test.ts",
        "packages/core/test/capability.test.ts"
      ],
      "qaSuites": [
        "pack_readiness"
      ],
      "liveArtifacts": [],
      "docs": [
        "README.md",
        "docs/RELEASE_TRAIN.md"
      ]
    }
  }
}
