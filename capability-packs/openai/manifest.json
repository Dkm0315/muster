{
  "schemaVersion": 1,
  "id": "openai",
  "name": "Muster OpenAI Provider",
  "version": "0.1.0",
  "kind": "tool",
  "slot": "provider",
  "entrypoint": "src/index.ts",
  "description": "Declarative OpenAI provider setup, readiness, model policy, and latency triage workflows.",
  "permissions": [],
  "sandbox": "read_only",
  "evals": [
    "evals/openai-provider.json"
  ],
  "implementedTools": [
    "openai_provider_setup_plan",
    "openai_provider_readiness",
    "openai_model_policy",
    "openai_latency_triage"
  ],
  "status": "v0: provider setup and model-routing guidance; live model probes stay explicit future provider checks.",
  "readiness": {
    "level": "setup_plan",
    "status": "beta",
    "actionability": "setup_plan",
    "owner": "muster-core",
    "surfaces": [
      "cli"
    ],
    "setup": {
      "urls": [
        "https://platform.openai.com/api-keys",
        "https://platform.openai.com/docs/models"
      ],
      "requiredEnv": [
        "OPENAI_API_KEY"
      ],
      "requiredAnyEnv": [],
      "credentialStorage": "env"
    },
    "diagnostics": {
      "doctorCommand": "muster plugins check openai",
      "smokeCommand": "muster capability inspect capability-packs/openai",
      "latencyBudgetMs": 1000,
      "requiresLiveCredentials": false
    },
    "safety": {
      "risk": "low",
      "permissionMode": "allow_when_scoped",
      "mutationApproval": "never",
      "resultCapBytes": 65536,
      "secretRedaction": true
    },
    "evidence": {
      "unitTests": [
        "packages/core/test/capability-load.test.ts",
        "packages/core/test/capability.test.ts"
      ],
      "qaSuites": [
        "pack_readiness"
      ],
      "liveArtifacts": [],
      "docs": [
        "README.md",
        "docs/RELEASE_TRAIN.md"
      ]
    }
  }
}
