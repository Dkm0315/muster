{
  "schemaVersion": 1,
  "id": "data-analytics",
  "name": "Muster Data Analytics",
  "version": "0.1.0",
  "kind": "tool",
  "slot": "data",
  "entrypoint": "src/index.ts",
  "description": "Local dataframe-style helpers for profiling rows, summarizing numeric fields, and preparing chart-ready records.",
  "permissions": [],
  "sandbox": "none",
  "evals": [
    "evals/data-analytics.json"
  ],
  "implementedTools": [
    "profile_rows",
    "numeric_summary"
  ],
  "status": "v0: pure row profiling; database MCPs remain the governed path for live data access.",
  "readiness": {
    "level": "executable",
    "status": "beta",
    "actionability": "local_tool",
    "owner": "muster-core",
    "surfaces": [
      "cli"
    ],
    "setup": {
      "urls": [],
      "requiredEnv": [
        "DATABASE_URL"
      ],
      "requiredAnyEnv": [],
      "credentialStorage": "env"
    },
    "diagnostics": {
      "doctorCommand": "muster plugins check data-analytics",
      "smokeCommand": "muster capability inspect capability-packs/data-analytics",
      "latencyBudgetMs": 1000,
      "requiresLiveCredentials": false
    },
    "safety": {
      "risk": "low",
      "permissionMode": "allow_when_scoped",
      "mutationApproval": "never",
      "resultCapBytes": 65536,
      "secretRedaction": true
    },
    "evidence": {
      "unitTests": [
        "packages/core/test/capability-load.test.ts",
        "packages/core/test/capability.test.ts"
      ],
      "qaSuites": [
        "pack_readiness"
      ],
      "liveArtifacts": [],
      "docs": [
        "README.md",
        "docs/RELEASE_TRAIN.md"
      ]
    }
  }
}
