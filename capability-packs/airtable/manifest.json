{
  "schemaVersion": 1,
  "id": "airtable",
  "name": "Muster Airtable",
  "version": "0.1.0",
  "kind": "tool",
  "slot": "productivity",
  "entrypoint": "src/index.ts",
  "description": "Airtable REST API tools for base discovery, schema inspection, record reads, creates, updates, and upserts. Uses an explicit Personal Access Token from the active capability context.",
  "permissions": [
    "network",
    "secrets"
  ],
  "sandbox": "network_limited",
  "secrets": [
    "AIRTABLE_API_KEY",
    "AIRTABLE_PAT"
  ],
  "evals": [
    "evals/airtable-api.json"
  ],
  "implementedTools": [
    "airtable_bases_list",
    "airtable_tables_list",
    "airtable_records_list",
    "airtable_record_get",
    "airtable_record_create",
    "airtable_record_update",
    "airtable_records_upsert"
  ],
  "status": "v0: direct Airtable REST API tools. Delete remains intentionally excluded; schema inspection before mutation is expected.",
  "readiness": {
    "level": "verified",
    "status": "beta",
    "actionability": "local_tool",
    "owner": "muster-core",
    "surfaces": [
      "cli"
    ],
    "setup": {
      "urls": [
        "https://airtable.com/create/tokens",
        "https://airtable.com/developers/web/api/introduction"
      ],
      "requiredEnv": [],
      "requiredAnyEnv": [
        [
          "AIRTABLE_API_KEY",
          "AIRTABLE_PAT"
        ]
      ],
      "credentialStorage": "env"
    },
    "diagnostics": {
      "doctorCommand": "muster plugins check airtable",
      "smokeCommand": "muster capability inspect capability-packs/airtable",
      "latencyBudgetMs": 1000,
      "requiresLiveCredentials": true
    },
    "safety": {
      "risk": "high",
      "permissionMode": "ask",
      "mutationApproval": "required",
      "resultCapBytes": 65536,
      "secretRedaction": true
    },
    "evidence": {
      "unitTests": [
        "packages/core/test/capability-load.test.ts",
        "packages/core/test/capability.test.ts"
      ],
      "qaSuites": [
        "pack_readiness"
      ],
      "liveArtifacts": [],
      "docs": [
        "README.md",
        "docs/RELEASE_TRAIN.md"
      ]
    }
  }
}
