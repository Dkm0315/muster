{
  "schemaVersion": 1,
  "id": "artifact-studio",
  "name": "Muster Artifact Studio",
  "version": "0.1.0",
  "kind": "tool",
  "slot": "artifacts",
  "entrypoint": "src/index.ts",
  "description": "Pure artifact helpers for turning structured inputs into markdown, CSV, dashboard manifests, DOCX, XLSX, PPTX, and simple PDF artifacts with app-server handoff planning for higher-fidelity creation.",
  "permissions": [],
  "sandbox": "none",
  "evals": [
    "evals/artifact-studio.json"
  ],
  "implementedTools": [
    "markdown_report",
    "rows_to_csv",
    "dashboard_manifest",
    "docx_document",
    "xlsx_workbook",
    "pptx_presentation",
    "pdf_document",
    "artifact_capability_plan"
  ],
  "status": "v0: deterministic artifact builders that return strings, JSON, or base64 file payloads for the caller to save, plus honest app-server handoff planning for polished document workflows.",
  "readiness": {
    "level": "executable",
    "status": "beta",
    "actionability": "local_tool",
    "owner": "muster-core",
    "surfaces": [
      "cli"
    ],
    "setup": {
      "urls": [],
      "requiredEnv": [],
      "requiredAnyEnv": [],
      "credentialStorage": "none"
    },
    "diagnostics": {
      "doctorCommand": "muster plugins check artifact-studio",
      "smokeCommand": "muster capability inspect capability-packs/artifact-studio",
      "latencyBudgetMs": 1000,
      "requiresLiveCredentials": false
    },
    "safety": {
      "risk": "low",
      "permissionMode": "allow_when_scoped",
      "mutationApproval": "never",
      "resultCapBytes": 1048576,
      "secretRedaction": true
    },
    "evidence": {
      "unitTests": [
        "packages/core/test/capability-load.test.ts",
        "packages/core/test/capability.test.ts",
        "packages/core/test/integration-packs.test.ts"
      ],
      "qaSuites": [
        "pack_readiness"
      ],
      "liveArtifacts": [],
      "docs": [
        "README.md",
        "docs/RELEASE_TRAIN.md"
      ]
    }
  }
}
